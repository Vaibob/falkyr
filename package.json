{
  "name": "jobpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "tsx src/server/index.ts",
    "ingest": "tsx src/ingest/cli.ts",
    "generate": "tsx src/generate/cli.ts",
    "apply": "tsx src/apply/cli.ts",
    "rewrite": "tsx src/generate/resume-cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "init": "tsx src/mcp/init.ts",
    "ui:dev": "vite --config web/vite.config.ts",
